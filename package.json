{
  "name": "perfume-analyzer",
  "version": "1.0.0",
  "private": true,
  "description": "Static-site perfumery raw materials analyzer + formulation engine. PubChem compound data, IFRA 51 caps, Edwards Fragrance Wheel taxonomy.",
  "type": "module",
  "scripts": {
    "lint": "eslint --max-warnings=0 \"index.html\" \"formulation.html\" \"tools/**/*.{js,mjs}\"",
    "lint:fix": "eslint --fix \"index.html\" \"formulation.html\" \"tools/**/*.{js,mjs}\"",
    "format": "prettier --write \"index.html\" \"formulation.html\" \"tools/**/*.{js,mjs}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"index.html\" \"formulation.html\" \"tools/**/*.{js,mjs}\" \"*.{json,md}\"",
    "lint:blends": "node tools/lint-blends.mjs"
  },
  "devDependencies": {
    "eslint": "^9.13.0",
    "@html-eslint/eslint-plugin": "^0.27.0",
    "@html-eslint/parser": "^0.27.0",
    "globals": "^15.11.0",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
