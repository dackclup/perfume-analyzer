{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "es5",
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 100,
  "arrowParens": "avoid",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "htmlWhitespaceSensitivity": "ignore",
  "overrides": [
    { "files": "*.json", "options": { "tabWidth": 2 } },
    { "files": "*.md", "options": { "proseWrap": "preserve" } }
  ]
}
